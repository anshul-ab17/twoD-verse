# HTTP port (default 2569)
# GATEWAY_PORT=2569

# Public base URL used to build OAuth redirect URIs
# PUBLIC_URL=http://localhost:2569

# Shared JWT secret (same one token.service reads across services)
JWT_SECRET=change-me

# Postgres (prisma client in @verse/db reads this)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/verse"

# OAuth (leave unset to disable a provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# presence reads (plan §7) — @verse/pubsub redis client
REDIS_URL=redis://localhost:6379
