# LiveKit credentials (cloud: https://cloud.livekit.io, or self-hosted livekit-server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
# MEDIA_PORT=2568
# must match the gateway's JWT_SECRET — media verifies gateway-issued access tokens
JWT_SECRET=dev-gateway-secret-do-not-use-in-prod
