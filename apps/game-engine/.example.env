# must match the gateway's JWT_SECRET — realtime verifies gateway-issued access tokens
JWT_SECRET=dev-gateway-secret-do-not-use-in-prod
# AUTH_OPTIONAL=1   # dev only: allow tokenless joins as guest-<sessionId>
# xp persistence (plan §3) — same DB as packages/db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/verse"
# presence (plan §7/§15) — @repo/pubsub redis client
REDIS_URL=redis://localhost:6379
