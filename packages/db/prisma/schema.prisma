generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  handle    String?  @unique
  password  String?
  role      Role     @default(USER)

  xp          Int       @default(0)
  level       Int       @default(1)
  lastDailyAt DateTime?
  questStep   Int       @default(0)
  focusStreak Int       @default(0)
  lastFocusAt DateTime?

  accounts  Account[]
  sessions  Session[]
  orgMemberships  OrgMember[]
  magicLinkTokens MagicLinkToken[]

  avatarId  String?
  avatar    Avatar?  @relation(fields: [avatarId], references: [id])

  spaces    Space[]  @relation("UserSpaces")
  messages  Message[]

  sentRequests       FriendRequest[] @relation("SentRequests")
  receivedRequests   FriendRequest[] @relation("ReceivedRequests")
  friendshipsA       Friendship[]    @relation("FriendshipsA")
  friendshipsB       Friendship[]    @relation("FriendshipsB")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id           String       @id @default(cuid())
  userId       String
  provider     AuthProvider
  providerId   String       

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime     @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  jti       String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Org {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free")

  members   OrgMember[]

  createdAt DateTime @default(now())
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)

  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

// ponytail: stores sha256(token) only — plaintext never persisted
model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  userId     String?
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?

  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@index([email])
}

model Space {
  id        String   @id @default(cuid())
  name      String
  width     Int
  height    Int

  creatorId String
  creator   User     @relation("UserSpaces", fields: [creatorId], references: [id], onDelete: Cascade)

  elements  SpaceElement[]
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpaceElement {
  id        String   @id @default(cuid())
  spaceId   String
  elementId String
  x         Int
  y         Int

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  element   Element  @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model Element {
  id        String   @id @default(cuid())
  width     Int
  height    Int
  imageUrl  String
  static    Boolean  @default(false)

  spaces    SpaceElement[]
  mapItems  MapElement[]

  createdAt DateTime @default(now())
}

model Map {
  id        String   @id @default(cuid())
  name      String
  width     Int
  height    Int

  elements  MapElement[]

  createdAt DateTime @default(now())
}

model MapElement {
  id        String   @id @default(cuid())
  mapId     String
  elementId String
  x         Int
  y         Int

  map       Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  element   Element  @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([mapId])
}

model Avatar {
  id        String   @id @default(cuid())
  imageUrl  String
  name      String?

  users     User[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  userId    String
  spaceId   String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([spaceId])
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}