# Copy to .env.prod on the Hetzner box and fill everything in.
IMAGE_PREFIX=ghcr.io/<your-github-username>
TAG=latest

POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=verse
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/verse
REDIS_URL=redis://redis:6379

# one strong secret shared by server/game-engine/rtc/assist
JWT_SECRET=change-me-64-random-chars

# your Vercel web app origin (CORS)
WEB_ORIGIN=https://your-app.vercel.app

# LiveKit (self-hosted on this box; keys must match livekit.yaml)
LIVEKIT_URL=wss://livekit.your-domain.com
LIVEKIT_API_KEY=prodkey
LIVEKIT_API_SECRET=change-me-livekit-secret

# AI notes (optional — service returns 503 without it)
ANTHROPIC_API_KEY=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
