# Caddy reverse proxy for the Hetzner box (default choice; nginx alternative
# lives in infra/nginx/twodverse.conf — run only one of the two).
# TLS certs are automatic (Let's Encrypt) — no certbot needed.
#
# Install:
#   apt install -y caddy
#   cp caddy.config /etc/caddy/Caddyfile
#   sed -i 's/your-domain.com/<apna-domain>/g' /etc/caddy/Caddyfile
#   systemctl reload caddy

# realtime (Colyseus) — WebSocket proxying is automatic in Caddy
rt.your-domain.com {
	reverse_proxy localhost:2567
}

# gateway (auth/social REST) — Caddy sends X-Forwarded-For by default,
# which the per-IP auth rate limit needs
api.your-domain.com {
	reverse_proxy localhost:2569
}

# media (LiveKit token service)
media.your-domain.com {
	reverse_proxy localhost:2568
}

# ai (meeting notes)
ai.your-domain.com {
	reverse_proxy localhost:2570
}

# livekit signalling (WebRTC media itself goes direct via UDP 50000-50100)
livekit.your-domain.com {
	reverse_proxy localhost:7880
}
